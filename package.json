{
  "name": "inkflow",
  "version": "0.1.0",
  "description": "A simple and clean Markdown editor for macOS and Linux",
  "main": "src/main/main.js",
  "author": {
    "name": "Inkflow Team",
    "email": "maintainer@example.com"
  },
  "homepage": "https://example.com/inkflow",
  "license": "MIT",
  "scripts": {
    "icons:build": "bash scripts/generate-icons.sh",
    "start": "electron .",
    "dev": "electron .",
    "dist": "npm run icons:build && electron-builder",
    "dist:mac": "npm run icons:build && electron-builder --mac",
    "dist:linux": "npm run icons:build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "marked": "^15.0.12",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.inkflow.app",
    "productName": "Inkflow",
    "icon": "build/icon.png",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "build/icon-512.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Inkflow Team <maintainer@example.com>",
      "category": "Office"
    }
  }
}
