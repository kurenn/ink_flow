{
  "name": "inkflow",
  "version": "0.1.1",
  "description": "A simple and clean Markdown editor for macOS and Linux",
  "main": "src/main/main.js",
  "author": {
    "name": "Inkflow Team",
    "email": "maintainer@example.com"
  },
  "homepage": "https://example.com/inkflow",
  "license": "MIT",
  "scripts": {
    "icons:build": "bash scripts/generate-icons.sh",
    "start": "electron .",
    "dev": "electron .",
    "dist": "npm run icons:build && electron-builder",
    "dist:release": "npm run dist:mac && npm run dist:linux",
    "dist:mac": "npm run icons:build && electron-builder --mac dmg zip --universal",
    "dist:mac:arm64": "npm run icons:build && electron-builder --mac dmg zip --arm64",
    "dist:mac:x64": "npm run icons:build && electron-builder --mac dmg zip --x64",
    "dist:linux": "npm run icons:build && electron-builder --linux AppImage deb --x64 --arm64"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "marked": "^15.0.12",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.inkflow.app",
    "productName": "Inkflow",
    "icon": "build/icon.png",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "build/icon-512.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Inkflow Team <maintainer@example.com>",
      "category": "Office"
    },
    "deb": {
      "fpm": [
        "--deb-no-default-config-files"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "abrahamkuri",
        "repo": "inkflow"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abrahamkuri/inkflow.git"
  }
}
